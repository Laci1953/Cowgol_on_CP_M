					E_exx();
					E_load16(REG_HL, param as [Symbol], 2);
					E_exx();
				end if;
		end case;

		count := count + 1;
	end loop;

	if pushed != 0 then
		E_push(REG_BC);
	end if;
	E_ret();

	EmitterCloseStream();

